# Telegram Bot Configuration
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
BOT_USERNAME=your_bot_username_here

# AI Provider API Keys
# Only the key for your DEFAULT_MODEL's provider is required.
# Leave the others empty if you don't use those providers.
OPENAI_API_KEY=your_openai_api_key_here      # Required for OpenAI models listed below
XAI_API_KEY=your_xai_api_key_here            # Required for grok-* models
GEMINI_API_KEY=your_gemini_api_key_here      # Required for gemini-* models

# Default model to use on first startup.
# After first run, the active model persists in the database and can be changed with /model.
# Available models: gpt-4o-mini, gpt-4.1-mini, gpt-5.4-mini, gpt-5,
#                   grok-4.20-0309-reasoning, grok-4.20-0309-non-reasoning, grok-4-1-fast-reasoning,
#                   gemini-3.1-flash-lite-preview, gemini-3-flash-preview
DEFAULT_MODEL=gpt-4.1-mini

# API timeout in seconds (increase for reasoning models which take longer)
OPENAI_TIMEOUT=60

# Token Budget Configuration
# MAX_CONTEXT_TOKENS: Maximum tokens to use for conversation context
# Recommended: Use 70-80% of your model's context window (e.g., 128000 for gpt-4o-mini)
MAX_CONTEXT_TOKENS=16000

# RESERVE_TOKENS_TEXT: Tokens reserved for text message responses
RESERVE_TOKENS_TEXT=1000

# RESERVE_TOKENS_IMAGE: Tokens reserved for image/vision responses
RESERVE_TOKENS_IMAGE=3000

# Group Chat Configuration
# MAX_GROUP_CONTEXT_MESSAGES: Maximum number of messages to store per group chat
MAX_GROUP_CONTEXT_MESSAGES=300

# Authorization
# Get your Telegram user ID from @userinfobot
AUTHORIZED_USER_ID=your_telegram_user_id_here

# Database
# Neon DB connection string (PostgreSQL)
# Format: postgresql://user:password@host:port/database?sslmode=require&channel_binding=require
DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require&channel_binding=require

# Logging (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
